Group #HotkeyPanel {
  LayoutMode: Top;
  Anchor: (Right: 12, Top: 12, Width: 270);
  Label #HotkeyTitle {
    Style: (FontSize: 25);
    Anchor: (Height: 37);
    Text: "HOTBAR KEYS";
  }
  Label #HK1 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[1]  Cancel / Deactivate";
  }
  Label #HK2 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[2]  Move Mode";
  }
  Label #HK3 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[3]  Select Spell";
  }
  Label #HK4 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[4]  Confirm Spell";
  }
  Label #HK5 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[5]  Add Target";
  }
  Label #HK6 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[6]  Cast / Fire";
  }
  Label #HK7 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[7]  Profile";
  }
  Label #HK8 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[8]  Spell List";
  }
  Label #HK9 {
    Style: (FontSize: 20);
    Anchor: (Height: 30);
    Text: "[9]  End Turn";
  }
  Label #HKCrouch {
    Style: (FontSize: 17);
    Anchor: (Height: 27);
    Text: "Crouch = Confirm / Scroll";
  }
}
